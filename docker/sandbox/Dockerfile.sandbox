# Production-hardened sandbox image supporting Python, Node.js, C++20, and OpenJDK 21.
FROM alpine:3.19

# Install runtimes and coreutils for robust base64 encoding support
RUN apk add --no-cache \
    python3 \
    nodejs \
    g++ \
    openjdk21-jdk \
    bash \
    coreutils

# Create an unprivileged non-root user
RUN adduser -D -u 10001 sandbox

USER sandbox
WORKDIR /home/sandbox
