        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[1m])) by (status, endpoint)",
          "legendFormat": "{{endpoint}} ({{status}})",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Request Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
