# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (relational / ACID)
POSTGRES_DB=dtae
POSTGRES_USER=dtae
POSTGRES_PASSWORD=dtae_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# CouchDB (document / MVCC)
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=dtae_secret
COUCHDB_DATABASE=dtae_documents

# Redis (Celery broker, Channels, throttles)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Rate limits
THROTTLE_USER_RATE=200/hour
THROTTLE_SUBMISSION_RATE=10/min

# Docker executor
DOCKER_EXECUTOR_IMAGE=dtae/python-sandbox:3.12
DOCKER_EXECUTOR_TIMEOUT_SECONDS=10
DOCKER_EXECUTOR_MEMORY_MB=128
